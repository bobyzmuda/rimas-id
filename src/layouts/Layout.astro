---
// src/layouts/Layout.astro
export interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Rumah Instan Modular Indonesia Emas - Solusi hunian cepat, tahan gempa, dan ramah lingkungan." />
  </head>
  <body>
    <slot />
  </body>
</html>