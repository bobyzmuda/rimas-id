---
// src/components/Contact.astro
---

<section class="contact-section section-padding" id="kontak">
    <div class="container">
        <div class="section-header reveal">
            <span class="section-tag">HUBUNGI KAMI</span>
            <h2 class="section-title">
                Siap <span class="highlight">Membangun Bersama</span>?
            </h2>
            <div class="section-divider"></div>
            <p class="section-desc">
                Tim ahli kami siap membantu konsultasi proyek Anda, baik untuk
                perorangan, pengembang, maupun program pemerintah.
            </p>
        </div>

        <div class="contact-grid">
            <!-- Kolom Kiri: Informasi -->
            <div class="contact-info reveal">
                <div class="info-block">
                    <div class="info-icon">
                        <i class="fa-solid fa-location-dot"></i>
                    </div>
                    <div>
                        <h4>Kantor Pusat</h4>
                        <p>
                            Komplek Mall, Perum Ruko Mutiara Taman Palem Blok C8
                            No. 8,<br />
                            RT.7/RW.14, Jalan Outer Ring Road Kamal Raya,<br />
                            Cengkareng Timur, West Jakarta City, Jakarta 11730
                        </p>
                        <a
                            href="https://maps.google.com/?q=Komplek+Mall+Perum+Ruko+Mutiara+Taman+Palem+Blok+C8+No.+8+Jakarta"
                            target="_blank"
                            rel="noopener"
                            class="map-link"
                        >
                            <i class="fa-solid fa-map-location-dot"></i> Buka di Google
                            Maps
                        </a>
                    </div>
                </div>

                <div class="info-block">
                    <div class="info-icon">
                        <i class="fa-solid fa-envelope"></i>
                    </div>
                    <div>
                        <h4>Email</h4>
                        <p>
                            <a href="mailto:pt.songsongindonesiaemas@gmail.com"
                                >pt.songsongindonesiaemas@gmail.com</a
                            >
                        </p>
                    </div>
                </div>

                <div class="info-block">
                    <div class="info-icon">
                        <i class="fa-solid fa-phone"></i>
                    </div>
                    <div>
                        <h4>WhatsApp / Telepon</h4>
                        <p>
                            <a href="https://wa.me/6287774889922"
                                >+62 877-7488-9922</a
                            >
                            <span class="contact-label">(Nadine)</span>
                            <br />
                            <a href="https://wa.me/6285280094852"
                                >+62 852-8009-4852</a
                            >
                            <span class="contact-label">(Imam)</span>
                        </p>
                    </div>
                </div>

                <div class="info-block">
                    <div class="info-icon">
                        <i class="fa-solid fa-globe"></i>
                    </div>
                    <div>
                        <h4>Website</h4>
                        <p>
                            <a href="https://www.rimas.id" target="_blank"
                                >www.rimas.id</a
                            >
                        </p>
                    </div>
                </div>
            </div>

            <!-- Kolom Kanan: Formulir -->
            <div class="contact-form-wrapper reveal reveal-delay-2">
                <form
                    action="https://formsubmit.co/pt.songsongindonesiaemas@gmail.com"
                    method="POST"
                >
                    <input type="hidden" name="_captcha" value="false" />
                    <input
                        type="hidden"
                        name="_subject"
                        value="Pertanyaan dari Website RIMAS"
                    />
                    <input type="hidden" name="_template" value="table" />

                    <div class="form-group">
                        <label for="name">Nama Lengkap</label>
                        <input
                            type="text"
                            id="name"
                            name="name"
                            placeholder="Nama Anda"
                            required
                        />
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            placeholder="email@anda.com"
                            required
                        />
                    </div>
                    <div class="form-group">
                        <label for="phone">Nomor WhatsApp</label>
                        <input
                            type="tel"
                            id="phone"
                            name="phone"
                            placeholder="08xx-xxxx-xxxx"
                        />
                    </div>
                    <div class="form-group">
                        <label for="message"
                            >Pesan / Tipe Rumah yang Diminati</label
                        >
                        <textarea
                            id="message"
                            name="message"
                            rows="4"
                            placeholder="Saya tertarik dengan Tipe 36 untuk proyek perumahan..."
                            required></textarea>
                    </div>
                    <button type="submit" class="submit-btn">
                        <i class="fa-solid fa-paper-plane"></i> Kirim Pesan
                    </button>
                </form>
                <p class="form-note">
                    <i class="fa-solid fa-lock"></i>
                    Data Anda aman dan hanya digunakan untuk keperluan konsultasi.
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .contact-section {
        background-color: var(--c-bg-light);
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
    }

    @media (min-width: 768px) {
        .contact-grid {
            grid-template-columns: 1fr 1fr;
            align-items: start;
        }
    }

    /* Info blocks */
    .contact-info {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .info-block {
        display: flex;
        gap: 1.2rem;
        align-items: flex-start;
        background: var(--c-surface);
        padding: 1.5rem;
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--c-border);
        transition:
            transform 0.25s,
            box-shadow 0.25s,
            border-color 0.25s;
    }

    .info-block:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
        border-color: rgba(201, 154, 59, 0.25);
    }

    .info-icon {
        font-size: 1.2rem;
        flex-shrink: 0;
        width: 3rem;
        height: 3rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(201, 154, 59, 0.1);
        color: var(--c-accent);
        border-radius: var(--radius-sm);
        transition: background 0.3s;
    }

    .info-block:hover .info-icon {
        background: rgba(201, 154, 59, 0.18);
    }

    .info-block h4 {
        font-size: 1rem;
        font-weight: 700;
        color: var(--c-text-dark);
        font-family: var(--font-heading);
        margin-bottom: 0.4rem;
    }

    .info-block p {
        color: var(--c-text-muted);
        font-size: 0.9rem;
        line-height: 1.6;
    }

    .info-block a {
        color: var(--c-text-dark);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s;
    }

    .info-block a:hover {
        color: var(--c-accent);
    }

    .contact-label {
        font-size: 0.78rem;
        color: var(--c-text-muted);
        font-weight: 400;
        margin-left: 0.2rem;
    }

    .map-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        margin-top: 0.8rem;
        font-size: 0.85rem;
        color: var(--c-accent) !important;
    }

    /* Form */
    .contact-form-wrapper {
        background: var(--c-surface);
        padding: 2.5rem 2rem;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        border: 1px solid var(--c-border);
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-group label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--c-text-dark);
        margin-bottom: 0.5rem;
        font-family: var(--font-heading);
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 0.9rem 1.1rem;
        border: 1.5px solid var(--c-border);
        border-radius: var(--radius-sm);
        font-size: 0.95rem;
        font-family: var(--font-body);
        transition: all 0.25s;
        background: var(--c-bg-light);
        box-sizing: border-box;
        color: var(--c-text-dark);
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--c-accent);
        background: var(--c-surface);
        box-shadow: 0 0 0 3px rgba(201, 154, 59, 0.12);
    }

    .form-group textarea {
        resize: vertical;
    }

    .submit-btn {
        width: 100%;
        padding: 0.95rem;
        background: var(--gradient-gold);
        color: var(--c-primary);
        font-weight: 700;
        font-family: var(--font-heading);
        font-size: 1rem;
        border: none;
        border-radius: var(--radius-md);
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        box-shadow: 0 6px 20px rgba(201, 154, 59, 0.3);
        position: relative;
        overflow: hidden;
    }

    .submit-btn::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.3) 0%,
            transparent 50%
        );
        opacity: 0;
        transition: opacity 0.3s;
    }

    .submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(201, 154, 59, 0.45);
    }

    .submit-btn:hover::after {
        opacity: 1;
    }

    .submit-btn:active {
        transform: scale(0.98);
    }

    .form-note {
        font-size: 0.8rem;
        color: var(--c-text-muted);
        text-align: center;
        margin-top: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
    }

    .form-note i {
        color: var(--c-accent);
        font-size: 0.75rem;
    }

    @media (max-width: 480px) {
        .contact-form-wrapper {
            padding: 1.5rem;
        }
        .info-block {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
    }
</style>
