---
// src/components/Contact.astro
---

<section class="contact-section" id="kontak">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">HUBUNGI KAMI</span>
            <h2 class="section-title">
                Siap <span class="highlight">Membangun Bersama</span>?
            </h2>
            <div class="section-divider"></div>
            <p class="section-desc">
                Tim ahli kami siap membantu konsultasi proyek Anda, baik untuk
                perorangan, pengembang, maupun program pemerintah.
            </p>
        </div>

        <div class="contact-grid">
            <!-- Kolom Kiri: Informasi -->
            <div class="contact-info">
                <div class="info-block">
                    <div class="info-icon">
                        <i class="fa-solid fa-location-dot"></i>
                    </div>
                    <div>
                        <h4>Kantor Pusat</h4>
                        <p>
                            Komplek Mall, Perum Ruko Mutiara Taman Palem Blok C8
                            No. 8,<br />
                            RT.7/RW.14, Jalan Outer Ring Road Kamal Raya,<br />
                            Cengkareng Timur, West Jakarta City, Jakarta 11730
                        </p>
                        <a
                            href="https://maps.google.com/?q=Komplek+Mall+Perum+Ruko+Mutiara+Taman+Palem+Blok+C8+No.+8+Jakarta"
                            target="_blank"
                            rel="noopener"
                            class="map-link"
                        >
                            <i class="fa-solid fa-map-location-dot"></i> Buka di Google
                            Maps
                        </a>
                    </div>
                </div>

                <div class="info-block">
                    <div class="info-icon">
                        <i class="fa-solid fa-envelope"></i>
                    </div>
                    <div>
                        <h4>Email</h4>
                        <p>
                            <a href="mailto:pt.songsongindonesiaemas@gmail.com"
                                >pt.songsongindonesiaemas@gmail.com</a
                            >
                        </p>
                    </div>
                </div>

                <div class="info-block">
                    <div class="info-icon">
                        <i class="fa-solid fa-phone"></i>
                    </div>
                    <div>
                        <h4>WhatsApp / Telepon</h4>
                        <p>
                            <a href="https://wa.me/6287774889922"
                                >+62 877-7488-9922</a
                            >
                            <span class="contact-label">(Nadine)</span>
                            <br />
                            <a href="https://wa.me/6285280094852"
                                >+62 852-8009-4852</a
                            >
                            <span class="contact-label">(Imam)</span>
                        </p>
                    </div>
                </div>

                <div class="info-block">
                    <div class="info-icon">
                        <i class="fa-solid fa-globe"></i>
                    </div>
                    <div>
                        <h4>Website</h4>
                        <p>
                            <a href="https://www.rimas.id" target="_blank"
                                >www.rimas.id</a
                            >
                        </p>
                    </div>
                </div>
            </div>

            <!-- Kolom Kanan: Formulir -->
            <div class="contact-form-wrapper">
                <form
                    action="https://formsubmit.co/pt.songsongindonesiaemas@gmail.com"
                    method="POST"
                >
                    <!-- Anti Spam (Opsional) -->
                    <input type="hidden" name="_captcha" value="false" />
                    <input
                        type="hidden"
                        name="_subject"
                        value="Pertanyaan dari Website RIMAS"
                    />
                    <input type="hidden" name="_template" value="table" />

                    <div class="form-group">
                        <label for="name">Nama Lengkap</label>
                        <input
                            type="text"
                            id="name"
                            name="name"
                            placeholder="Nama Anda"
                            required
                        />
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            placeholder="email@anda.com"
                            required
                        />
                    </div>
                    <div class="form-group">
                        <label for="phone">Nomor WhatsApp</label>
                        <input
                            type="tel"
                            id="phone"
                            name="phone"
                            placeholder="08xx-xxxx-xxxx"
                        />
                    </div>
                    <div class="form-group">
                        <label for="message"
                            >Pesan / Tipe Rumah yang Diminati</label
                        >
                        <textarea
                            id="message"
                            name="message"
                            rows="4"
                            placeholder="Saya tertarik dengan Tipe 36 untuk proyek perumahan..."
                            required></textarea>
                    </div>
                    <button type="submit" class="submit-btn"
                        ><i class="fa-solid fa-paper-plane"></i> Kirim Pesan</button
                    >
                </form>
                <p class="form-note">
                    <i class="fa-solid fa-lock" style="color: var(--c-accent)"
                    ></i> * Data Anda aman dan hanya digunakan untuk keperluan konsultasi.
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .contact-section {
        background-color: var(--c-bg-light);
    }
    .container {
        max-width: 1100px;
        margin: 0 auto;
    }
    .section-header {
        text-align: center;
        margin-bottom: 3rem;
    }
    .section-tag {
        display: inline-block;
        background: rgba(201, 154, 59, 0.15);
        color: var(--c-accent);
        padding: 0.4rem 1.2rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
    }
    .section-title {
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 800;
        color: var(--c-text-dark);
        margin-bottom: 0;
    }
    .section-title .highlight {
        color: var(--c-accent);
    }
    .section-desc {
        color: var(--c-text-muted);
        max-width: 650px;
        margin: 0 auto;
        font-size: 1.1rem;
        line-height: 1.6;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
    }
    @media (min-width: 768px) {
        .contact-grid {
            grid-template-columns: 1fr 1fr;
            align-items: start;
        }
    }

    /* Kolom Kiri */
    .contact-info {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    .info-block {
        display: flex;
        gap: 1.2rem;
        align-items: flex-start;
        background: #ffffff;
        padding: 1.8rem;
        border-radius: 1.5rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
        border: 1px solid #e9edf2;
        transition:
            transform 0.25s,
            box-shadow 0.25s;
    }
    .info-block:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.06);
        border-color: rgba(201, 154, 59, 0.3);
    }
    .info-icon {
        font-size: 1.5rem;
        flex-shrink: 0;
        width: 3.5rem;
        height: 3.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(201, 154, 59, 0.1);
        color: var(--c-accent);
        border-radius: 50%;
    }
    .info-block h4 {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--c-text-dark);
        font-family: var(--font-heading);
        margin: 0 0 0.5rem 0;
    }
    .info-block p {
        margin: 0;
        color: var(--c-text-muted);
        font-size: 0.95rem;
        line-height: 1.6;
    }
    .info-block a {
        color: var(--c-primary);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s;
    }
    .info-block a:hover {
        color: var(--c-accent);
    }
    .contact-label {
        font-size: 0.8rem;
        color: #94a3b8;
        font-weight: 400;
        margin-left: 0.3rem;
    }
    .map-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        margin-top: 0.8rem;
        font-size: 0.9rem;
        color: var(--c-accent) !important;
    }

    /* Kolom Kanan */
    .contact-form-wrapper {
        background: #ffffff;
        padding: 2.5rem 2rem;
        border-radius: 1.5rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        border: 1px solid #e9edf2;
    }
    .form-group {
        margin-bottom: 1.5rem;
    }
    .form-group label {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--c-text-dark);
        margin-bottom: 0.5rem;
    }
    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 1rem 1.2rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 1rem;
        font-size: 1rem;
        font-family: var(--font-body);
        transition: all 0.25s;
        background: #f8fafc;
        box-sizing: border-box;
        color: var(--c-text-dark);
    }
    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--c-accent);
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(201, 154, 59, 0.1);
    }
    .form-group textarea {
        resize: vertical;
    }

    .submit-btn {
        width: 100%;
        padding: 1rem;
        background: var(--c-primary);
        color: var(--c-text-white);
        font-weight: 700;
        font-family: var(--font-heading);
        font-size: 1.1rem;
        border: none;
        border-radius: 1rem;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        box-shadow: 0 4px 15px rgba(10, 22, 40, 0.2);
    }
    .submit-btn:hover {
        background: var(--c-accent);
        color: var(--c-primary);
        transform: scale(1.02);
        box-shadow: 0 8px 25px rgba(201, 154, 59, 0.3);
    }
    .submit-btn:active {
        transform: scale(0.98);
    }

    .form-note {
        font-size: 0.85rem;
        color: var(--c-text-muted);
        text-align: center;
        margin-top: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
    }

    @media (max-width: 480px) {
        .contact-form-wrapper {
            padding: 1.5rem;
        }
        .info-block {
            padding: 1.5rem;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .info-icon {
            width: 3.5rem;
        }
    }
</style>
