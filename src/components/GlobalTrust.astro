---
// src/components/GlobalTrust.astro
const projects = [
    {
        country: "Korea Selatan",
        icon: "fa-solid fa-globe",
        desc: "Luxury modular in Paju",
        bgColor: "bg-korea",
    },
    {
        country: "Pakistan",
        icon: "fa-solid fa-globe",
        desc: "170m² unit besar untuk hunian keluarga",
        bgColor: "bg-pakistan",
    },
    {
        country: "Nikaragua",
        icon: "fa-solid fa-globe",
        desc: "42m² hunian sosial cepat bangun",
        bgColor: "bg-nikaragua",
    },
    {
        country: "Kuba",
        icon: "fa-solid fa-globe",
        desc: "42m² house at an affordable price",
        bgColor: "bg-kuba",
    },
];
---

<section class="global-section" id="global">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">GLOBAL TRUST</span>
            <h2 class="section-title">
                Terbukti di <span class="highlight">Seluruh Dunia</span>
            </h2>
            <div class="section-divider"></div>
            <p class="section-desc">
                Keandalan teknologi modular ini telah terbukti secara global. Di
                bawah lisensi G-Songuo, rumah modular telah sukses dibangun dan
                berpenghuni di berbagai negara.
            </p>
        </div>

        <div class="projects-grid">
            {
                projects.map((item) => (
                    <div class={`project-card ${item.bgColor}`}>
                        <div class="card-flag">
                            <i class={item.icon} />
                        </div>
                        <div class="card-content">
                            <h4>{item.country}</h4>
                            <p>{item.desc}</p>
                        </div>
                    </div>
                ))
            }
        </div>

        <div class="trust-badge">
            <i class="fa-solid fa-building-circle-check"></i>
            <strong>G-Songuo Composites Technology Co., Ltd</strong>
            <span>— Teknologi Berlisensi Global</span>
        </div>
    </div>
</section>

<style>
    .global-section {
        background-color: #ffffff;
    }
    .container {
        max-width: 1100px;
        margin: 0 auto;
    }
    .section-header {
        text-align: center;
        margin-bottom: 3rem;
    }
    .section-tag {
        display: inline-block;
        background: rgba(201, 154, 59, 0.15);
        color: var(--c-accent);
        padding: 0.4rem 1.2rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
    }
    .section-title {
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 800;
        color: var(--c-text-dark);
        margin-bottom: 0;
    }
    .section-title .highlight {
        color: var(--c-accent);
    }
    .section-desc {
        color: var(--c-text-muted);
        max-width: 700px;
        margin: 0 auto;
        font-size: 1.1rem;
        line-height: 1.6;
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }
    @media (min-width: 768px) {
        .projects-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    .project-card {
        padding: 2rem 1.5rem;
        border-radius: 1.5rem;
        text-align: center;
        transition:
            transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid #e9edf2;
        background: var(--c-bg-light);
    }
    .project-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
    }

    .project-card.bg-korea {
        border-top: 4px solid var(--c-accent);
    }
    .project-card.bg-pakistan {
        border-top: 4px solid var(--c-accent);
    }
    .project-card.bg-nikaragua {
        border-top: 4px solid var(--c-accent);
    }
    .project-card.bg-kuba {
        border-top: 4px solid var(--c-accent);
    }

    .card-flag {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 0.8rem;
        color: var(--c-text-dark);
        opacity: 0.8;
    }
    .project-card h4 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--c-text-dark);
        margin: 0 0 0.5rem 0;
        font-family: var(--font-heading);
    }
    .project-card p {
        font-size: 0.9rem;
        color: var(--c-text-muted);
        margin: 0;
        line-height: 1.5;
    }

    .trust-badge {
        text-align: center;
        padding: 1.5rem;
        background: var(--c-primary);
        color: var(--c-text-white);
        border-radius: 1rem;
        font-size: 1rem;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        box-shadow: 0 10px 25px rgba(10, 22, 40, 0.2);
    }
    .trust-badge i {
        color: var(--c-accent);
        font-size: 1.25rem;
    }
    .trust-badge span {
        color: var(--c-accent);
    }
    .trust-badge strong {
        color: var(--c-text-white);
        font-weight: 700;
    }

    @media (max-width: 480px) {
        .projects-grid {
            grid-template-columns: 1fr 1fr;
        }
        .project-card {
            padding: 1.5rem 1rem;
        }
        .card-flag {
            font-size: 2rem;
        }
    }
</style>
