---
// src/components/Comparison.astro
const rows = [
    {
        label: "Metode Konstruksi",
        conventional: "Struktur bata tradisional atau beton bertulang (RC)",
        rimas: "Rangka baja ringan + sistem panel modular",
    },
    {
        label: "Waktu Konstruksi",
        conventional: "30-80 hari",
        rimas: "1 unit per hari (min. 100 unit) dengan 8 pekerja",
    },
    {
        label: "Desain",
        conventional: "Gaya atap datar sederhana, fasad standar",
        rimas: "Pilihan atap pelana/shed dan 100 pilihan fasad",
    },
    {
        label: "Keamanan Struktur",
        conventional: "Risiko runtuh akibat bata & atap semen",
        rimas: "Struktur pabrik, stabilitas tinggi & tahan gempa 7.5 SR",
    },
    {
        label: "Termal / Kedap Air",
        conventional: "Rendah (risiko panas berlebih, bocor)",
        rimas: "Panel komposit berinsulasi, isolasi & kedap air unggul",
    },
    {
        label: "Ketergantungan Tenaga Kerja",
        conventional: "Membutuhkan banyak pekerja terampil",
        rimas: "Tenaga kerja minimal, bisa pakai pekerja tidak terampil",
    },
    {
        label: "Kontrol Kualitas",
        conventional: "Bervariasi tergantung lokasi & skill",
        rimas: "Komponen standar pabrik (presisi tinggi)",
    },
    {
        label: "Kemudahan Ekspansi",
        conventional: "Sulit dikembangkan",
        rimas: "Mudah dengan menambahkan modul",
    },
    {
        label: "Efisiensi Biaya",
        conventional: "Biaya awal rendah, perawatan jangka panjang tinggi",
        rimas: "Hemat biaya, perawatan rendah, umur pakai panjang",
    },
    {
        label: "Efisiensi Energi",
        conventional: "Isolasi buruk, biaya AC tinggi",
        rimas: "Insulasi canggih, hemat AC hingga 70%",
    },
    {
        label: "Dampak Lingkungan",
        conventional: "Banyak limbah & debu di lokasi",
        rimas: "Zero Waste (pabrikasi & rakit di lokasi)",
    },
];

const perspectives = [
    {
        icon: "fa-solid fa-building-columns",
        title: "Perspektif Pemerintah",
        desc: "Kecepatan pembangunan, standarisasi, dan daya tahan membuat RIMAS cocok untuk pengembangan perumahan massal dan jangka panjang.",
        highlight: false,
    },
    {
        icon: "fa-solid fa-users",
        title: "Perspektif Penghuni",
        desc: "Tingkat kepuasan tinggi berkat efisiensi energi, estetika, keamanan struktur, dan pemanfaatan ruang interior yang optimal.",
        highlight: true,
    },
    {
        icon: "fa-solid fa-briefcase",
        title: "Perspektif Pengembang",
        desc: "Hemat biaya tenaga kerja dan kecepatan pembangunan (ready to sell), serta kualitas rumah yang meningkatkan kepuasan pembeli.",
        highlight: false,
    },
];
---

<section class="comparison-section section-padding" id="perbandingan">
    <div class="container">
        <div class="section-header reveal">
            <span class="section-tag">PERBANDINGAN</span>
            <h2 class="section-title">
                RIMAS vs <span class="highlight">Rumah Konvensional</span>
            </h2>
            <div class="section-divider"></div>
            <p class="section-desc">
                Lihat sendiri perbedaan mendasar yang menjadikan RIMAS pilihan
                cerdas untuk masa depan.
            </p>
        </div>

        <div class="table-wrapper reveal">
            <table>
                <thead>
                    <tr>
                        <th>Aspek</th>
                        <th>Perumahan Konvensional</th>
                        <th class="rimas-header">
                            <i class="fa-solid fa-check-double"></i> RIMAS
                        </th>
                    </tr>
                </thead>
                <tbody>
                    {
                        rows.map((row) => (
                            <tr>
                                <td class="label-cell">{row.label}</td>
                                <td class="conventional-cell">
                                    <i class="fa-solid fa-xmark cell-icon-bad" />
                                    {row.conventional}
                                </td>
                                <td class="rimas-cell">
                                    <i class="fa-solid fa-check cell-icon-good" />
                                    {row.rimas}
                                </td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>

        <div class="perspectives reveal">
            <div class="perspectives-grid">
                {
                    perspectives.map((item, i) => (
                        <div
                            class={`perspective-card reveal reveal-delay-${i + 1} ${item.highlight ? "highlight-card" : ""}`}
                        >
                            <div
                                class={`p-icon ${item.highlight ? "p-icon-gold" : ""}`}
                            >
                                <i class={item.icon} />
                            </div>
                            <h4>{item.title}</h4>
                            <p>{item.desc}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style>
    .comparison-section {
        background-color: var(--c-surface);
    }

    /* Table */
    .table-wrapper {
        overflow-x: auto;
        border-radius: var(--radius-lg);
        border: 1px solid var(--c-border);
        background: var(--c-surface);
        box-shadow: var(--shadow-md);
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
        min-width: 650px;
    }

    thead th {
        padding: 1.1rem 1.5rem;
        text-align: left;
        background: var(--c-primary);
        color: var(--c-text-white);
        font-weight: 700;
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-family: var(--font-heading);
    }

    thead th.rimas-header {
        background: var(--c-accent);
        color: var(--c-primary);
    }

    thead th.rimas-header i {
        margin-right: 0.3rem;
    }

    tbody td {
        padding: 0.85rem 1.5rem;
        border-bottom: 1px solid var(--c-border-light);
        vertical-align: top;
        line-height: 1.5;
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    tbody tr {
        transition: background 0.2s;
    }

    tbody tr:hover {
        background: rgba(201, 154, 59, 0.03);
    }

    .label-cell {
        font-weight: 700;
        color: var(--c-text-dark);
        background: #fbfcfe;
        white-space: nowrap;
        font-size: 0.88rem;
    }

    .conventional-cell {
        color: var(--c-text-muted);
    }

    .rimas-cell {
        color: #15803d;
        font-weight: 600;
        background: rgba(34, 197, 94, 0.04);
    }

    .cell-icon-bad {
        color: #ef4444;
        margin-right: 0.5rem;
        font-size: 0.7rem;
        opacity: 0.7;
    }

    .cell-icon-good {
        color: #22c55e;
        margin-right: 0.5rem;
        font-size: 0.7rem;
    }

    /* Perspectives */
    .perspectives {
        margin-top: 4rem;
    }

    .perspectives-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    @media (max-width: 768px) {
        .perspectives-grid {
            grid-template-columns: 1fr;
            max-width: 480px;
            margin: 0 auto;
        }
    }

    .perspective-card {
        background: var(--c-bg-light);
        padding: 2.5rem 2rem;
        border-radius: var(--radius-lg);
        border: 1px solid var(--c-border);
        transition:
            transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.35s;
    }

    .perspective-card:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-lg);
    }

    .perspective-card.highlight-card {
        border-color: var(--c-accent);
        background: var(--c-surface);
        box-shadow: 0 8px 30px rgba(201, 154, 59, 0.1);
    }

    .p-icon {
        width: 3.2rem;
        height: 3.2rem;
        border-radius: var(--radius-sm);
        background: rgba(10, 22, 40, 0.06);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: var(--c-primary);
        margin-bottom: 1.2rem;
        transition: transform 0.3s;
    }

    .perspective-card:hover .p-icon {
        transform: scale(1.1);
    }

    .p-icon-gold {
        background: rgba(201, 154, 59, 0.12);
        color: var(--c-accent);
    }

    .perspective-card h4 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--c-text-dark);
        margin-bottom: 0.8rem;
        font-family: var(--font-heading);
    }

    .highlight-card h4 {
        color: var(--c-accent);
    }

    .perspective-card p {
        font-size: 0.92rem;
        color: var(--c-text-muted);
        line-height: 1.65;
    }

    @media (max-width: 480px) {
        .perspective-card {
            padding: 1.8rem 1.5rem;
        }
    }
</style>
