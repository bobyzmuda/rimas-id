---
// src/components/Hero.astro
---

<section class="hero" id="beranda">
    <div class="hero-bg-overlay"></div>
    <div class="hero-particles">
        <div class="particle p1"></div>
        <div class="particle p2"></div>
        <div class="particle p3"></div>
    </div>
    <div class="hero-container">
        <span class="badge reveal">
            <i class="fa-solid fa-award"></i> RIMAS — Rumah Instan Modular Indonesia
            Emas
        </span>
        <h1 class="hero-title reveal reveal-delay-1">
            Membangun Rumah Rakyat.<br />
            <span class="highlight">Cepat</span> dan <span class="highlight"
                >Tahan Lama</span
            >.
        </h1>
        <p class="hero-desc reveal reveal-delay-2">
            Solusi hunian berteknologi global G-Songuo, siap huni dalam hitungan
            hari. Tahan gempa 7.5 SR, Zero Waste, dan efisien energi.
        </p>
        <div class="hero-features reveal reveal-delay-3">
            <span
                ><i class="fa-solid fa-shield-halved"></i> Tahan Gempa 7.5 SR</span
            >
            <span
                ><i class="fa-solid fa-recycle"></i> Zero Waste Konstruksi</span
            >
            <span><i class="fa-solid fa-gauge-high"></i> 1 Unit per Hari</span>
        </div>
        <div class="hero-actions reveal reveal-delay-4">
            <a href="#produk" class="btn-primary">
                <i class="fa-solid fa-house"></i> Lihat Produk
            </a>
            <a href="#kontak" class="btn-outline">
                <i class="fa-solid fa-headset"></i> Konsultasi Gratis
            </a>
        </div>

        <div class="hero-gallery reveal">
            <div class="gallery-card">
                <img src="/assets/tipe-27.png" alt="Rumah Tipe 27" />
                <div class="gallery-label">Tipe 27</div>
            </div>
            <div class="gallery-card">
                <img src="/assets/section.png" alt="Section" />
                <div class="gallery-label">Section</div>
            </div>
            <div class="gallery-card">
                <img src="/assets/rumah-contoh.png" alt="Rumah Contoh" />
                <div class="gallery-label">Rumah Contoh</div>
            </div>
            <div class="gallery-card">
                <img src="/assets/interior.png" alt="Interior Modern" />
                <div class="gallery-label">Interior</div>
            </div>
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        background-color: var(--c-primary);
        background-image: url("https://placehold.co/1920x1080/0A1628/0A1628?text=.");
        background-size: cover;
        background-position: center;
        padding: 8rem 1.5rem 5rem;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--c-text-white);
        text-align: center;
        overflow: hidden;
    }

    .hero-bg-overlay {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(
                ellipse at 20% 50%,
                rgba(201, 154, 59, 0.08) 0%,
                transparent 50%
            ),
            radial-gradient(
                ellipse at 80% 20%,
                rgba(15, 31, 56, 0.9) 0%,
                transparent 60%
            ),
            linear-gradient(
                180deg,
                rgba(10, 22, 40, 0.97) 0%,
                rgba(12, 26, 48, 0.92) 100%
            );
        z-index: 1;
    }

    /* Floating ambient particles */
    .hero-particles {
        position: absolute;
        inset: 0;
        z-index: 2;
        pointer-events: none;
        overflow: hidden;
    }

    .particle {
        position: absolute;
        border-radius: 50%;
        background: radial-gradient(
            circle,
            rgba(201, 154, 59, 0.3) 0%,
            transparent 70%
        );
        animation: floatParticle 12s ease-in-out infinite;
    }

    .p1 {
        width: 300px;
        height: 300px;
        top: 10%;
        left: -5%;
        animation-delay: 0s;
    }
    .p2 {
        width: 200px;
        height: 200px;
        bottom: 20%;
        right: -3%;
        animation-delay: -4s;
    }
    .p3 {
        width: 150px;
        height: 150px;
        top: 50%;
        left: 60%;
        animation-delay: -8s;
        opacity: 0.5;
    }

    @keyframes floatParticle {
        0%,
        100% {
            transform: translate(0, 0) scale(1);
        }
        33% {
            transform: translate(30px, -20px) scale(1.05);
        }
        66% {
            transform: translate(-15px, 15px) scale(0.95);
        }
    }

    .hero-container {
        max-width: 1000px;
        margin: 0 auto;
        width: 100%;
        position: relative;
        z-index: 3;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        background: rgba(201, 154, 59, 0.1);
        color: var(--c-accent);
        padding: 0.5rem 1.5rem;
        border-radius: var(--radius-full);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        margin-bottom: 2rem;
        border: 1px solid rgba(201, 154, 59, 0.2);
        backdrop-filter: blur(8px);
    }

    .hero-title {
        font-size: clamp(2.5rem, 7vw, 4.2rem);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        color: var(--c-text-white);
        letter-spacing: -0.03em;
    }

    .hero-title .highlight {
        background: var(--gradient-gold);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-desc {
        font-size: clamp(1rem, 2vw, 1.2rem);
        color: rgba(255, 255, 255, 0.7);
        max-width: 620px;
        margin: 0 auto 2rem;
        line-height: 1.7;
    }

    .hero-features {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem 2rem;
        margin-bottom: 2.5rem;
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.85);
        font-weight: 500;
    }

    .hero-features span {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--radius-full);
        backdrop-filter: blur(4px);
    }

    .hero-features span i {
        color: var(--c-accent);
        font-size: 0.85rem;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
    }

    .btn-outline {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1.5px solid rgba(255, 255, 255, 0.35);
        color: #ffffff;
        padding: 0.85rem 2.5rem;
        border-radius: var(--radius-md);
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: var(--font-heading);
    }

    .btn-outline:hover {
        background: rgba(201, 154, 59, 0.15);
        border-color: var(--c-accent);
        color: var(--c-accent);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(201, 154, 59, 0.2);
    }

    /* Gallery */
    .hero-gallery {
        margin-top: 4rem;
        display: flex;
        gap: 1.25rem;
        overflow-x: auto;
        padding: 1rem 0 1.5rem;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
    }

    .hero-gallery::-webkit-scrollbar {
        height: 4px;
    }
    .hero-gallery::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
    }
    .hero-gallery::-webkit-scrollbar-thumb {
        background: var(--c-accent);
        border-radius: 10px;
    }

    .gallery-card {
        flex-shrink: 0;
        width: 260px;
        position: relative;
        border-radius: var(--radius-md);
        overflow: hidden;
        scroll-snap-align: center;
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: all 0.3s;
    }

    .gallery-card:hover {
        border-color: var(--c-accent);
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
    }

    .gallery-card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        display: block;
        transition: transform 0.4s;
    }

    .gallery-card:hover img {
        transform: scale(1.08);
    }

    .gallery-label {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 0.7rem 1rem;
        background: linear-gradient(transparent, rgba(10, 22, 40, 0.9));
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--c-text-white);
        font-family: var(--font-heading);
    }

    @media (max-width: 768px) {
        .hero {
            padding: 7rem 1rem 4rem;
            min-height: auto;
        }
        .gallery-card {
            width: 220px;
        }
        .gallery-card img {
            height: 150px;
        }
    }
</style>
