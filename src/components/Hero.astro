---
// src/components/Hero.astro
---

<section class="hero" id="beranda">
    <div class="hero-bg-overlay"></div>
    <div class="hero-container">
        <span class="badge"
            ><i class="fa-solid fa-trophy"></i> RIMAS - Rumah Instan Modular Indonesia
            Emas</span
        >
        <h1 class="hero-title">
            Membangun Rumah Rakyat.<br />
            <span class="highlight">Cepat</span> dan <span class="highlight"
                >Tahan Lama</span
            >.
        </h1>
        <p class="hero-desc">
            Solusi hunian berteknologi global G-Songuo, siap huni dalam hitungan
            hari. Tahan gempa 7.5 SR, Zero Waste, dan efisien energi.
        </p>
        <div class="hero-features">
            <span
                ><i
                    class="fa-solid fa-circle-check"
                    style="color: var(--c-accent)"></i> Tahan Gempa 7.5 SR</span
            >
            <span
                ><i
                    class="fa-solid fa-circle-check"
                    style="color: var(--c-accent)"></i> Zero Waste Konstruksi</span
            >
            <span
                ><i
                    class="fa-solid fa-circle-check"
                    style="color: var(--c-accent)"></i> 1 Unit per Hari</span
            >
        </div>
        <div class="hero-actions">
            <a href="#produk" class="btn-primary">Lihat Produk</a>
            <a href="#kontak" class="btn-secondary">Konsultasi Gratis</a>
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        background-color: var(--c-primary);
        background-image: url("https://placehold.co/1200x600/0A1628/1E293B?text=Hero+Background");
        background-size: cover;
        background-position: center;
        padding: 6rem 1.5rem;
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--c-text-white);
        text-align: center;
        z-index: 1;
    }
    .hero-bg-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            rgba(10, 22, 40, 0.95) 0%,
            rgba(30, 41, 59, 0.85) 100%
        );
        z-index: -1;
    }
    .hero-container {
        max-width: 900px;
        margin: 0 auto;
    }
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(201, 154, 59, 0.15);
        color: var(--c-accent);
        padding: 0.5rem 1.5rem;
        border-radius: 99px;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(201, 154, 59, 0.3);
    }
    .hero-title {
        font-size: clamp(2.5rem, 8vw, 4.5rem);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        color: var(--c-text-white);
    }
    .hero-title .highlight {
        color: var(--c-accent);
        text-shadow: 0 0 20px rgba(201, 154, 59, 0.3);
    }
    .hero-desc {
        font-size: clamp(1rem, 2vw, 1.25rem);
        color: #e2e8f0;
        max-width: 650px;
        margin: 0 auto 2rem;
        line-height: 1.6;
    }
    .hero-features {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1.5rem 2.5rem;
        margin-bottom: 2.5rem;
        font-size: 0.95rem;
        color: #f1f5f9;
        font-weight: 500;
    }
    .hero-features span {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
    }
    .btn-secondary {
        display: inline-block;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: var(--c-text-white);
        padding: 0.8rem 2.5rem;
        border-radius: 1rem;
        font-weight: 600;
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s;
    }
    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: scale(1.03);
    }
</style>
