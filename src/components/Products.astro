---
// src/components/Products.astro
const products = [
    {
        id: "27",
        size: "27 m²",
        price: "Rp79.650.000",
        roof: "Atap Gable Roof",
        features: [
            "Rangka modular baja galvanis",
            "Panel EPS insulasi grafit",
            "Lantai PVC + lis",
            "Sanitasi & kelistrikan siap pakai",
        ],
        badge: "Strategi",
        icon: "fa-solid fa-house",
        desc: "Solusi cerdas untuk hunian kompak atau proyek perumahan massal.",
        imageText: "Denah+Tipe+27",
    },
    {
        id: "30",
        size: "30 m²",
        price: "Rp88.500.000",
        roof: "Atap Shed / Datar",
        features: [
            "Rangka modular baja galvanis",
            "Panel EPS insulasi grafit",
            "Lantai PVC + lis",
            "Ruang lebih luas untuk keluarga",
        ],
        badge: "Best Value",
        icon: "fa-solid fa-star",
        desc: "Pilihan paling seimbang antara harga dan kenyamanan.",
        imageText: "Denah+Tipe+30",
    },
    {
        id: "36",
        size: "36 m²",
        price: "Rp106.200.000",
        roof: "Atap Gable / Shed",
        features: [
            "Rangka modular baja galvanis",
            "Panel EPS insulasi grafit",
            "Lantai PVC + lis",
            "3 Kamar Tidur atau ruang fleksibel",
        ],
        badge: "Keluarga",
        icon: "fa-solid fa-users",
        desc: "Pilihan ideal untuk hunian tumbuh (expandable).",
        imageText: "Denah+Tipe+36",
    },
];
---

<section class="products-section" id="produk">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">PILIHAN HUNIAN</span>
            <h2 class="section-title">Tipe Rumah Modular RIMAS</h2>
            <div class="section-divider"></div>
            <p class="section-desc">
                Dari lahan 27m² hingga 36m², setiap jengkal ruang dioptimalkan
                untuk kenyamanan Anda.
            </p>
        </div>

        <div class="products-grid">
            {
                products.map((product) => (
                    <div class="product-card">
                        <div class="card-badge">
                            <i class={product.icon} /> {product.badge}
                        </div>
                        <img
                            src={`https://placehold.co/600x400/E2E8F0/1E293B?text=${product.imageText}`}
                            alt={`Denah Tipe ${product.id}`}
                            class="product-image"
                        />
                        <div class="card-content">
                            <h3 class="product-type">Tipe {product.id}</h3>
                            <p class="product-size">{product.size}</p>
                            <p class="product-roof">{product.roof}</p>
                            <div class="price-tag">{product.price}</div>
                            <ul class="product-features">
                                {product.features.map((feature) => (
                                    <li>{feature}</li>
                                ))}
                            </ul>
                            <p class="product-desc">{product.desc}</p>
                            <a href="#kontak" class="card-cta">
                                Tanya & Pesan{" "}
                                <i class="fa-solid fa-arrow-right" />
                            </a>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .products-section {
        background-color: var(--c-bg-light);
    }
    .container {
        max-width: 1200px;
        margin: 0 auto;
    }
    .section-header {
        text-align: center;
        margin-bottom: 3.5rem;
    }
    .section-tag {
        display: inline-block;
        background: rgba(201, 154, 59, 0.15);
        color: var(--c-accent);
        padding: 0.4rem 1.2rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
    }
    .section-title {
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 800;
        color: var(--c-text-dark);
        margin-bottom: 0;
    }
    .section-desc {
        color: var(--c-text-muted);
        max-width: 600px;
        margin: 0 auto;
        font-size: 1.1rem;
        line-height: 1.6;
    }
    .products-grid {
        display: grid;
        grid-template-columns: repeat(1, 1fr);
        gap: 2rem;
    }
    @media (min-width: 768px) {
        .products-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
    .product-card {
        background: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        position: relative;
        transition:
            transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        border: 1px solid #e9edf2;
        overflow: hidden;
    }
    .product-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
        border-color: var(--c-accent);
    }
    .card-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: var(--c-primary);
        color: var(--c-text-white);
        padding: 0.4rem 1rem;
        border-radius: 99px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        z-index: 10;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    }
    .product-image {
        width: 100%;
        height: 220px;
        object-fit: cover;
        border-bottom: 1px solid #e9edf2;
    }
    .card-content {
        padding: 2rem 1.8rem;
        display: flex;
        flex-direction: column;
        flex: 1;
    }
    .product-type {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--c-text-dark);
        margin-bottom: 0.2rem;
    }
    .product-size {
        font-size: 0.95rem;
        color: var(--c-text-muted);
        font-weight: 500;
        margin-bottom: 0.4rem;
    }
    .product-roof {
        font-size: 0.85rem;
        color: #64748b;
        margin-bottom: 1.2rem;
        border-bottom: 1px dashed #e2e8f0;
        padding-bottom: 1rem;
    }
    .price-tag {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--c-text-dark);
        margin-bottom: 1.2rem;
        font-family: var(--font-heading);
    }
    .price-tag::before {
        content: "Mulai ";
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--c-text-muted);
        font-family: var(--font-body);
    }
    .product-features {
        list-style: none;
        padding: 0;
        margin: 0 0 1.5rem 0;
        flex: 1;
    }
    .product-features li {
        padding: 0.4rem 0;
        color: #334155;
        font-size: 0.95rem;
        display: flex;
        align-items: flex-start;
        gap: 0.8rem;
    }
    .product-features li::before {
        font-family: "Font Awesome 6 Free";
        font-weight: 900;
        content: "\f00c";
        color: var(--c-accent);
        font-size: 1rem;
        margin-top: 0.1rem;
    }
    .product-desc {
        font-size: 0.9rem;
        color: #64748b;
        line-height: 1.5;
        margin-bottom: 1.5rem;
        font-style: italic;
    }
    .card-cta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        background: var(--c-primary);
        color: var(--c-text-white);
        text-align: center;
        padding: 0.8rem 1.5rem;
        border-radius: 1rem;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition:
            background 0.25s,
            transform 0.2s;
        margin-top: auto;
    }
    .card-cta:hover {
        background: var(--c-accent);
        color: var(--c-primary);
        transform: translateY(-2px);
    }
</style>
