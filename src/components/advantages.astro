---
// src/components/Advantages.astro
const advantages = [
    {
        icon: "fa-solid fa-shield-halved",
        title: "Material PosMAC",
        subtitle: "5-10x Lebih Kuat dari Baja Galvanis",
        description:
            "Teknologi baja pelat tercanggih dengan ketahanan korosi luar biasa. Kekakuan dinding dan lantai dirancang untuk bertahan lintas generasi.",
        color: "gold",
    },
    {
        icon: "fa-solid fa-helmet-safety",
        title: "Tahan Gempa 7.5 SR",
        subtitle: "Keamanan Struktural Maksimal",
        description:
            "Telah lulus uji simulasi Computer-Aided Engineering (CAE) ketat. Kokoh menahan angin kencang dan guncangan gempa terkuat.",
        color: "blue",
    },
    {
        icon: "fa-solid fa-snowflake",
        title: "Insulasi Premium",
        subtitle: "Hemat Energi hingga 70%",
        description:
            "Busa poliuretan premium menghasilkan ruangan stabil: adem di siang hari, kedap suara, dan tahan api. Bebas overheat dan kebocoran.",
        color: "green",
    },
];
---

<section class="advantages-section" id="keunggulan">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">KEUNGGULAN RIMAS</span>
            <h2 class="section-title">
                Teknologi untuk <span class="highlight">Hunian Masa Depan</span>
            </h2>
            <div class="section-divider"></div>
            <p class="section-desc">
                Dirancang dengan material canggih dan standar global untuk
                kenyamanan lintas generasi.
            </p>
        </div>

        <div class="advantages-grid">
            {
                advantages.map((item, index) => (
                    <div class={`advantage-card ${item.color}`}>
                        <div class="card-icon">
                            <i class={item.icon} />
                        </div>
                        <h3 class="card-title">{item.title}</h3>
                        <p class="card-subtitle">{item.subtitle}</p>
                        <p class="card-desc">{item.description}</p>
                        <div class="card-number">0{index + 1}</div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .advantages-section {
        background-color: var(--c-primary);
        color: var(--c-text-white);
    }
    .container {
        max-width: 1200px;
        margin: 0 auto;
    }
    .section-header {
        text-align: center;
        margin-bottom: 3.5rem;
    }
    .section-tag {
        display: inline-block;
        background: rgba(201, 154, 59, 0.15);
        color: var(--c-accent);
        padding: 0.4rem 1.2rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
        border: 1px solid rgba(201, 154, 59, 0.2);
    }
    .section-title {
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 800;
        margin-bottom: 0;
    }
    .section-title .highlight {
        color: var(--c-accent);
    }
    .section-desc {
        color: var(--c-text-muted);
        max-width: 600px;
        margin: 0 auto;
        font-size: 1.1rem;
        line-height: 1.6;
    }

    .advantages-grid {
        display: grid;
        grid-template-columns: repeat(1, 1fr);
        gap: 2rem;
    }
    @media (min-width: 768px) {
        .advantages-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .advantage-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border-radius: 1.5rem;
        padding: 2.5rem 2rem;
        position: relative;
        overflow: hidden;
        transition:
            transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .advantage-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    .advantage-card.gold:hover {
        border-color: rgba(201, 154, 59, 0.3);
        box-shadow: 0 20px 40px rgba(201, 154, 59, 0.1);
    }
    .advantage-card.blue:hover {
        border-color: rgba(56, 189, 248, 0.3);
        box-shadow: 0 20px 40px rgba(56, 189, 248, 0.1);
    }
    .advantage-card.green:hover {
        border-color: rgba(52, 211, 153, 0.3);
        box-shadow: 0 20px 40px rgba(52, 211, 153, 0.1);
    }

    .card-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        display: inline-block;
        color: var(--c-text-white);
    }
    .card-title {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
        color: var(--c-text-white);
        font-family: var(--font-heading);
    }
    .card-subtitle {
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }
    .advantage-card.gold .card-icon,
    .advantage-card.gold .card-subtitle {
        color: var(--c-accent);
    }
    .advantage-card.blue .card-icon,
    .advantage-card.blue .card-subtitle {
        color: #38bdf8;
    }
    .advantage-card.green .card-icon,
    .advantage-card.green .card-subtitle {
        color: #34d399;
    }

    .card-desc {
        color: #cbd5e1;
        font-size: 0.95rem;
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }
    .card-number {
        position: absolute;
        bottom: -0.5rem;
        right: 1rem;
        font-size: 5rem;
        font-weight: 900;
        opacity: 0.05;
        color: var(--c-text-white);
        line-height: 1;
        font-family: var(--font-heading);
    }

    @media (max-width: 480px) {
        .advantage-card {
            padding: 1.8rem 1.5rem;
        }
        .card-icon {
            font-size: 2rem;
        }
        .card-title {
            font-size: 1.2rem;
        }
    }
</style>
